# NVIDIA NIM (OpenAI-compatible)
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Qdrant Cloud
QDRANT_URL=
QDRANT_API_KEY=

# Neo4j Aura (Phase 2+)
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Neon Postgres (Phase 3+)
DATABASE_URL=

# Upstash Redis (Phase 3+)
REDIS_URL=

# Models (pinned)
LLM_MODEL=meta/llama-3.3-70b-instruct
FAST_LLM_MODEL=meta/llama-3.1-8b-instruct
EMBED_MODEL=nvidia/nv-embedqa-e5-v5
RERANK_MODEL=nvidia/nv-rerankqa-mistral-4b-v3
EMBED_DIM=1024

# Ingestion tuning
EMBED_BATCH_SIZE=32
NIM_MAX_CONCURRENT=4
